<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.frontend.HelloController">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
  </padding>

  <Label text="تست ارتباط Frontend → Backend" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
  <Label fx:id="welcomeText" text="روی دکمه کلیک کن..." style="-fx-font-size: 14px;"/>
  <Button text="🔗 تست اتصال به Backend" onAction="#onHelloButtonClick"
          style="-fx-font-size: 14px; -fx-padding: 10px 20px;"/>
</VBox>