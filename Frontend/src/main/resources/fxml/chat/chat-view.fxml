<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.chat.ChatController">
    <children>
        <!-- بخش اصلی چت با عرض محدود در وسط صفحه جهت زیبایی و خوانایی بیشتر در صفحات عریض -->
        <VBox alignment="TOP_CENTER" spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="10.0">
            <children>
                <!-- هدر چت -->
                <HBox alignment="CENTER_RIGHT" prefHeight="65.0" prefWidth="1080.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <children>
                        <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="chatTitleLabel" text="گفتگو درباره آگهی" textFill="#1e293b">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Label fx:id="chatSubtitleLabel" text="در حال اتصال..." textFill="#64748b">
                                    <font>
                                        <Font size="12.0" />
                                    </font>
                                </Label>
                            </children>
                            <HBox.margin>
                                <Insets right="20.0" />
                            </HBox.margin>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="بازگشت">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                            <HBox.margin>
                                <Insets right="15.0" />
                            </HBox.margin>
                            <padding>
                                <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
                            </padding>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                    </padding>
                </HBox>

                <!-- کادر گفتگوها -->
                <ScrollPane fx:id="scrollPane" fitToWidth="true" prefHeight="530.0" style="-fx-background-color: transparent; -fx-background: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="messageContainer" spacing="12.0">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- فیلد تایپ و دکمه ارسال پیام -->
                <HBox alignment="CENTER" prefHeight="60.0" spacing="12.0">
                    <children>
                        <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 25; -fx-cursor: hand;" text="ارسال">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                        <TextField fx:id="messageTextField" onAction="#handleSendMessage" prefHeight="45.0" promptText="پیام خود را در اینجا بنویسید..." style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-border-color: #cbd5e1; -fx-padding: 0 20 0 20; -fx-alignment: center-right;" HBox.hgrow="ALWAYS">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </TextField>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
