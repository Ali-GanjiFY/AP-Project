<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="20.0" styleClass="auth-container"
      nodeOrientation="RIGHT_TO_LEFT"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.frontend.auth.LoginController">

    <!-- لود کردن فایل‌های CSS -->
    <!-- لود کردن فایل‌های CSS از ریشه منابع (Absolute Paths) -->
    <stylesheets>
        <URL value="@/css/variables.css" />
        <URL value="@/css/main.css" />
        <URL value="@/css/auth.css" />
    </stylesheets>


    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- تیتر صفحه -->
    <Label text="ورود به حساب کاربری" styleClass="auth-title" />

    <VBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="نام کاربری:" styleClass="sub-label" />
        <TextField fx:id="usernameField" promptText="نام کاربری خود را وارد کنید"
                   styleClass="text-field" prefWidth="300.0" />
    </VBox>

    <VBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="رمز عبور:" styleClass="sub-label" />
        <PasswordField fx:id="passwordField" promptText="********"
                       styleClass="password-field" prefWidth="300.0" />
    </VBox>

    <!-- دکمه ورود -->
    <Button fx:id="loginButton" text="ورود" onAction="#handleLogin"
            styleClass="button" prefWidth="300.0" />

    <!-- لینک ثبت‌نام -->
    <HBox alignment="CENTER" spacing="5.0">
        <Label text="حساب کاربری ندارید؟" />
        <Hyperlink text="ثبت‌نام کنید" onAction="#navigateToRegister" styleClass="auth-link" />
    </HBox>

    <!-- پیام خطا (در ابتدا مخفی است) -->
    <Label fx:id="errorLabel" text="" styleClass="error-text" visible="false" />

</VBox>

