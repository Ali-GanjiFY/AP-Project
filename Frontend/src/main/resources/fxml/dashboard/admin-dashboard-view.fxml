<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.frontend.dashboard.AdminDashboardController"
           nodeOrientation="RIGHT_TO_LEFT"
           prefWidth="1280" prefHeight="720">

    <stylesheets>
        <URL value="@../../css/variables.css"/>
        <URL value="@../../css/main.css"/>
    </stylesheets>

    <children>
        <StackPane style="-fx-background-color: #f8fafc;" StackPane.alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <StackPane.margin>
                <Insets left="250.0"/>
            </StackPane.margin>

            <VBox spacing="20">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="داشبورد آماری ادمین"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label text="در این بخش خلاصه‌ای از وضعیت کاربران، آگهی‌ها و بررسی‌های مدیریتی را مشاهده می‌کنید."
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <Button text="بروزرسانی آمار" onAction="#handleRefresh"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <Separator/>

                <Label fx:id="statusLabel" text="در حال بارگذاری آمار داشبورد..."
                       style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>

                <GridPane hgap="18" vgap="18">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <VBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="0"
                          style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 22;">
                        <Label text="تعداد کاربران"
                               style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="usersCountLabel" text="..."
                               style="-fx-font-size: 34px; -fx-text-fill: #2563eb; -fx-font-weight: bold;"/>
                        <Label text="کل کاربران ثبت‌شده در سامانه"
                               style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="1"
                          style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 22;">
                        <Label text="تعداد آگهی‌ها"
                               style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="advertisementsCountLabel" text="..."
                               style="-fx-font-size: 34px; -fx-text-fill: #16a34a; -fx-font-weight: bold;"/>
                        <Label text="کل آگهی‌های ثبت‌شده در سامانه"
                               style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="2"
                          style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 22;">
                        <Label text="بررسی‌های مدیر"
                               style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="adminReviewsCountLabel" text="..."
                               style="-fx-font-size: 34px; -fx-text-fill: #7c3aed; -fx-font-weight: bold;"/>
                        <Label text="تعداد تصمیم‌های ثبت‌شده توسط مدیر"
                               style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="3"
                          style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 22;">
                        <Label text="در انتظار بررسی"
                               style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="pendingAdsCountLabel" text="..."
                               style="-fx-font-size: 34px; -fx-text-fill: #f59e0b; -fx-font-weight: bold;"/>
                        <Label text="آگهی‌های دارای وضعیت PENDING"
                               style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                    </VBox>
                </GridPane>

                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-padding: 22;">
                    <Label text="دسترسی‌های سریع"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                    <HBox spacing="12">
                        <Button text="مدیریت کاربران" onAction="#handleManageUsers"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

                        <Button text="بررسی آگهی‌ها" onAction="#handleReviewAds"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

                        <Button text="کل آگهی‌ها" onAction="#handleAllAds"
                                style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

                        <Button text="مدیریت بخش‌ها" onAction="#handleManageSections"
                                style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>
        </StackPane>

        <VBox spacing="15" prefWidth="250.0" maxWidth="250.0"
              style="-fx-background-color: #0f172a;"
              StackPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <Label text="پنل مدیریت (ادمین)"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Separator style="-fx-opacity: 0.3;"/>

            <Button text="داشبورد" onAction="#handleRefresh" maxWidth="Infinity" styleClass="menu-button"
                    style="-fx-text-fill: #ffffff; -fx-background-color: #334155;"/>

            <Button text="مدیریت کاربران" onAction="#handleManageUsers" maxWidth="Infinity" styleClass="menu-button"/>

            <Button text="بررسی آگهی‌ها" onAction="#handleReviewAds" maxWidth="Infinity" styleClass="menu-button"/>

            <Button text="کل آگهی‌ها" onAction="#handleAllAds" maxWidth="Infinity" styleClass="menu-button"/>

            <Button text="مدیریت بخش‌ها" onAction="#handleManageSections" maxWidth="Infinity" styleClass="menu-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-opacity: 0.3;"/>

            <Button text="خروج از حساب" onAction="#handleLogout" maxWidth="Infinity"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </VBox>
    </children>
</StackPane>
