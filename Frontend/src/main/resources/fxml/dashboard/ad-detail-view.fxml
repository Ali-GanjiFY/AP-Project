<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.frontend.dashboard.AdDetailController"
            nodeOrientation="RIGHT_TO_LEFT"
            prefWidth="1280" prefHeight="720"
            style="-fx-background-color: #f8fafc;">

    <stylesheets>
        <URL value="@../../css/variables.css"/>
        <URL value="@../../css/main.css"/>
    </stylesheets>

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="12"
              style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-padding: 18 24 18 24;">
            <Button text="بازگشت"
                    onAction="#handleBack"
                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Label text="جزئیات آگهی"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 24;">

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 20;">
                        <Label fx:id="titleLabel"
                               text="عنوان آگهی"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="priceLabel"
                               text="قیمت"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
                    </VBox>

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 20;">
                        <Label text="تصاویر آگهی"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <StackPane minHeight="320" prefHeight="320"
                                   style="-fx-background-color: #f1f5f9; -fx-background-radius: 10;">
                            <Label fx:id="imageStatusLabel"
                                   text="بدون تصویر"
                                   style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                            <ImageView fx:id="mainImageView"
                                       fitWidth="500" fitHeight="300"
                                       preserveRatio="true"/>
                        </StackPane>
                        <HBox alignment="CENTER" spacing="16">
                            <Button fx:id="prevImageButton" text="قبلی"
                                    onAction="#handlePrevImage"
                                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-cursor: hand;"/>
                            <Label fx:id="imageCounterLabel" text=""
                                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                            <Button fx:id="nextImageButton" text="بعدی"
                                    onAction="#handleNextImage"
                                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 20;">
                        <Label text="اطلاعات آگهی"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                        <Label fx:id="categoryLabel"
                               text="دسته‌بندی: -"
                               style="-fx-font-size: 14px; -fx-text-fill: #334155;"/>

                        <Label fx:id="cityLabel"
                               text="شهر: -"
                               style="-fx-font-size: 14px; -fx-text-fill: #334155;"/>

                        <Label fx:id="statusLabel"
                               text="وضعیت: فعال"
                               style="-fx-font-size: 14px; -fx-text-fill: #334155;"/>

                        <Label fx:id="ownerLabel"
                               text="فروشنده: -"
                               style="-fx-font-size: 14px; -fx-text-fill: #334155;"/>

                        <Button text="شروع گفتگو با فروشنده"
                                onAction="#handleStartChat"
                                maxWidth="Infinity"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 16 10 16; -fx-background-radius: 8;"/>
                    </VBox>

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 20;">
                        <Label text="توضیحات"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextArea fx:id="descriptionArea"
                                  editable="false"
                                  wrapText="true"
                                  prefHeight="220"
                                  style="-fx-font-size: 14px; -fx-control-inner-background: #f8fafc;"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>