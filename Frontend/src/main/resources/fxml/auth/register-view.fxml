<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.frontend.auth.RegisterController"
           nodeOrientation="RIGHT_TO_LEFT"
           styleClass="scroll-container">

    <children>
        <VBox alignment="CENTER"
              spacing="15.0"
              styleClass="auth-container"
              maxWidth="460.0"
              maxHeight="-Infinity"
              StackPane.alignment="CENTER">

            <padding>
                <Insets top="30.0" right="40.0" bottom="30.0" left="40.0" />
            </padding>

            <Label text="ایجاد حساب کاربری جدید" styleClass="auth-title" />

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="نام و نام خانوادگی:" styleClass="sub-label" />
                <TextField fx:id="fullNameField"
                           promptText="نام کامل خود را وارد کنید"
                           styleClass="text-field"
                           prefWidth="380.0" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="نام کاربری:" styleClass="sub-label" />
                <TextField fx:id="usernameField"
                           promptText="نام کاربری"
                           styleClass="text-field"
                           prefWidth="380.0" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="شماره تلفن همراه:" styleClass="sub-label" />
                <TextField fx:id="phoneField"
                           promptText="09123456789"
                           styleClass="text-field"
                           prefWidth="380.0" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="ایمیل (اختیاری):" styleClass="sub-label" />
                <TextField fx:id="emailField"
                           promptText="example@email.com"
                           styleClass="text-field"
                           prefWidth="380.0" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="رمز عبور:" styleClass="sub-label" />
                <PasswordField fx:id="passwordField"
                               promptText="حداقل ۶ کاراکتر"
                               styleClass="password-field"
                               prefWidth="380.0" />
            </VBox>

            <Button fx:id="registerButton"
                    text="ثبت‌نام"
                    onAction="#handleRegister"
                    styleClass="button"
                    prefWidth="380.0" />

            <HBox alignment="CENTER" spacing="5.0">
                <Label text="قبلاً ثبت‌نام کرده‌اید؟" />
                <Hyperlink text="ورود به حساب کاربری"
                           onAction="#navigateToLogin"
                           styleClass="auth-link" />
            </HBox>

            <Label fx:id="errorLabel"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   wrapText="true"
                   maxWidth="380.0" />
        </VBox>

        <ImageView fitWidth="180.0"
                   preserveRatio="true"
                   StackPane.alignment="TOP_CENTER">
            <StackPane.margin>
                <Insets/>
            </StackPane.margin>
            <Image url="@../../images/splash.png"/>
        </ImageView>
    </children>
</StackPane>