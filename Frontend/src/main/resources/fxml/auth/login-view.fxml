<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.frontend.auth.LoginController"
           nodeOrientation="RIGHT_TO_LEFT"
           styleClass="scroll-container">

    <children>
        <ImageView fitWidth="200.0"
                   preserveRatio="true"
                   StackPane.alignment="TOP_CENTER">
            <StackPane.margin>
                <Insets top="50.0" bottom="50.0"/>
            </StackPane.margin>
            <Image url="@../../images/splash.png" />
        </ImageView>

        <VBox alignment="CENTER"
              spacing="18.0"
              styleClass="auth-container"
              maxWidth="460.0"
              maxHeight="-Infinity"
              StackPane.alignment="CENTER">

            <padding>
                <Insets top="30.0" right="36.0" bottom="30.0" left="36.0"/>
            </padding>

            <Label text="ورود به حساب کاربری" styleClass="auth-title"/>

            <VBox spacing="6.0" alignment="CENTER_LEFT">
                <Label text="نام کاربری:" styleClass="sub-label"/>
                <TextField fx:id="usernameField"
                           promptText="نام کاربری"
                           styleClass="text-field"
                           prefWidth="360.0"/>
            </VBox>

            <VBox spacing="6.0" alignment="CENTER_LEFT">
                <Label text="رمز عبور:" styleClass="sub-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="رمز عبور"
                               styleClass="password-field"
                               prefWidth="360.0"/>
            </VBox>

            <Button text="ورود"
                    onAction="#handleLogin"
                    styleClass="button"
                    prefWidth="360.0"/>

            <Label fx:id="errorLabel"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   wrapText="true"
                   maxWidth="360.0"/>

            <HBox alignment="CENTER" spacing="6.0">
                <Label text="حساب ندارید؟"/>
                <Hyperlink text="ایجاد حساب"
                           onAction="#navigateToRegister"
                           styleClass="auth-link"/>
            </HBox>

        </VBox>
    </children>
</StackPane>